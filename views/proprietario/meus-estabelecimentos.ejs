<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Meus Estabelecimentos</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include('../partials/header') %>

  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2><i class="bi bi-shop"></i> Meus Estabelecimentos</h2>
      <a href="/estabelecimentos/novo" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Novo
      </a>
    </div>

    <div id="lista-meus" class="row"></div>
  </div>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    $(document).ready(function () {
      $.get('/api/estabelecimentos/me/listar', function (data) {
        if (data.length === 0) {
          $('#lista-meus').html(`
            <div class="col-12 text-center py-5">
              <i class="bi bi-shop display-1 text-muted"></i>
              <h4 class="mt-3 text-muted">Você ainda não cadastrou nenhum estabelecimento</h4>
              <a href="/estabelecimentos/novo" class="btn btn-primary mt-3">Cadastrar agora</a>
            </div>
          `);
          return;
        }

        let html = '';
        data.forEach(est => {
          html += `
            <div class="col-md-4 mb-4">
              <div class="card h-100 shadow-sm">
                <img src="${est.foto_url || '/img/default.jpg'}" 
                     class="card-img-top" style="height:180px; object-fit:cover;">
                <div class="card-body">
                  <h5>${est.nome}</h5>
                  <span class="badge bg-info">${est.categoria}</span>
                  <p class="mt-2 mb-1">
                    ⭐ ${parseFloat(est.media_estrelas).toFixed(1)} 
                    <small class="text-muted">(${est.total_avaliacoes} avaliações)</small>
                  </p>
                  <p class="text-muted small mb-0">${est.endereco}</p>
                </div>
                <div class="card-footer bg-transparent">
                  <a href="/estabelecimento/${est.id}" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-eye"></i> Ver
                  </a>
                  <button class="btn btn-sm btn-outline-danger btn-excluir" data-id="${est.id}">
                    <i class="bi bi-trash"></i> Excluir
                  </button>
                </div>
              </div>
            </div>`;
        });
        $('#lista-meus').html(html);
      });

      $(document).on('click', '.btn-excluir', function () {
        if (!confirm('Excluir este estabelecimento?')) return;
        const id = $(this).data('id');
        $.ajax({
          url: `/api/estabelecimentos/${id}`,
          method: 'DELETE',
          success: () => location.reload()
        });
      });
    });
  </script>
</body>
</html>