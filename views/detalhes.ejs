<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= estabelecimento.nome %> — Guia do Aluno
  </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    .hero-img {
      width: 100%;
      height: 350px;
      object-fit: cover;
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    }

    .estrela-grande {
      font-size: 1.8rem;
      color: #ffc107;
    }

    .comentario-card {
      border-left: 4px solid #0d6efd;
      background: #f8f9fa;
      padding: 1rem;
      margin-bottom: 1rem;
      border-radius: 6px;
    }

    .badge-categoria {
      font-size: 0.9rem;
      padding: 0.4rem 0.8rem;
    }
  </style>
</head>

<body class="bg-light">

  <!-- Navbar -->
  <%- include('partials/header') %>

    <div class="container mb-5">
      <div class="row g-4">

        <!-- Coluna esquerda: informações principais -->
        <div class="col-lg-7">
          <img src="<%= estabelecimento.foto_url || '/img/default.jpg' %>" alt="<%= estabelecimento.nome %>"
            class="hero-img mb-3">

          <h1 class="mb-2">
            <%= estabelecimento.nome %>
          </h1>

          <span class="badge bg-info badge-categoria me-2">
            <i class="bi bi-tag"></i>
            <%= estabelecimento.categoria %>
          </span>
          <span class="badge bg-secondary badge-categoria">
            <i class="bi bi-geo-alt"></i>
            <%= estabelecimento.endereco %>
          </span>

          <div class="mt-3 p-3 bg-white rounded shadow-sm">
            <h5 class="mb-2">Avaliação geral</h5>
            <div class="d-flex align-items-center gap-3">
              <span class="display-4 fw-bold text-primary">
                <%= parseFloat(estabelecimento.media_estrelas).toFixed(1) %>
              </span>
              <div>
                <div class="estrela-grande">
                  <% for (let i=1; i <=5; i++) { %>
                    <% if (i <=Math.round(estabelecimento.media_estrelas)) { %>
                      <i class="bi bi-star-fill"></i>
                      <% } else { %>
                        <i class="bi bi-star"></i>
                        <% } %>
                          <% } %>
                </div>
                <small class="text-muted">
                  Baseado em <%= estabelecimento.total_avaliacoes %> avaliação(ões)
                </small>
              </div>
            </div>
          </div>

          <div class="mt-3 p-3 bg-white rounded shadow-sm">
            <h5><i class="bi bi-chat-left-text"></i> Comentários</h5>
            <% if (avaliacoes.length===0) { %>
              <p class="text-muted mt-3">
                <i class="bi bi-emoji-frown"></i> Ainda não há comentários. Seja o primeiro!
              </p>
              <% } else { %>
                <div class="mt-3">
                  <% avaliacoes.forEach(av=> { %>
                    <div class="comentario-card">
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                          <% for (let i=1; i <=5; i++) { %>
                            <% if (i <=av.nota) { %>
                              <i class="bi bi-star-fill text-warning"></i>
                              <% } else { %>
                                <i class="bi bi-star text-warning"></i>
                                <% } %>
                                  <% } %>
                        </div>
                        <small class="text-muted">
                          <%= new Date(av.criado_em).toLocaleDateString('pt-BR') %>
                        </small>
                      </div>
                      <% if (av.comentario && av.comentario.trim()) { %>
                        <p class="mb-0">
                          <%= av.comentario %>
                        </p>
                        <% } else { %>
                          <p class="mb-0"><em class="text-muted">Sem comentário</em></p>
                          <% } %>
                    </div>
                    <% }) %>
                </div>
                <% } %>
          </div>
        </div>

        <!-- Coluna direita: formulário de avaliação -->
        <div class="col-lg-5">
          <div class="card shadow-sm sticky-top" style="top: 20px;">
            <div class="card-body">
              <h5 class="card-title mb-3">
                <i class="bi bi-pencil-square"></i> Deixe sua avaliação
              </h5>

              <form id="form-avaliacao">
                <input type="hidden" id="estabelecimento_id" value="<%= estabelecimento.id %>">

                <div class="mb-3">
                  <label class="form-label fw-bold">Sua nota</label>
                  <div id="estrelas-input" class="d-flex gap-1">
                    <% [1,2,3,4,5].forEach(n=> { %>
                      <i class="bi bi-star estrela-input" data-nota="<%= n %>"
                        style="font-size: 2rem; cursor: pointer; color: #ccc;"></i>
                      <% }) %>
                  </div>
                  <input type="hidden" id="nota" name="nota" value="0" required>
                  <small class="text-muted">Clique nas estrelas para avaliar</small>
                </div>

                <div class="mb-3">
                  <label for="comentario" class="form-label fw-bold">Comentário</label>
                  <textarea class="form-control" id="comentario" name="comentario" rows="4"
                    placeholder="Conte como foi sua experiência..."></textarea>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                  <i class="bi bi-send"></i> Enviar Avaliação
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Toast de feedback -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
      <div id="toast" class="toast align-items-center text-white bg-success border-0" role="alert">
        <div class="d-flex">
          <div class="toast-body" id="toast-msg">Avaliação enviada!</div>
          <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
      </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/detalhes.js"></script>
</body>

</html>