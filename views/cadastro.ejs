<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cadastro — Guia do Aluno</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    .perfil-card {
      border: 2px solid #dee2e6;
      border-radius: 10px;
      padding: 1.5rem;
      cursor: pointer;
      transition: all 0.2s;
      text-align: center;
    }
    .perfil-card:hover {
      border-color: #0d6efd;
      background: #f8f9ff;
    }
    .perfil-card.selected {
      border-color: #0d6efd;
      background: #e7f1ff;
      box-shadow: 0 0 0 3px rgba(13,110,253,0.2);
    }
    .perfil-card i { font-size: 2.5rem; display: block; margin-bottom: 0.5rem; }
  </style>
</head>
<body class="bg-light">
  <div class="container">
    <div class="row justify-content-center mt-5">
      <div class="col-md-6">
        <div class="card shadow">
          <div class="card-body p-4">
            <h3 class="text-center mb-4">
              <i class="bi bi-utensils"></i> Guia do Aluno
            </h3>
            <h5 class="text-center text-muted mb-4">Criar Conta</h5>

            <% if (mensagens.erro && mensagens.erro.length > 0) { %>
              <div class="alert alert-danger"><%= mensagens.erro[0] %></div>
            <% } %>

            <form action="/cadastro" method="POST">
              <div class="mb-3">
                <label for="nome" class="form-label">Nome completo</label>
                <input type="text" class="form-control" id="nome" name="nome" required>
              </div>

              <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" class="form-control" id="email" name="email" required>
              </div>

              <div class="row mb-3">
                <div class="col-md-6">
                  <label for="senha" class="form-label">Senha</label>
                  <input type="password" class="form-control" id="senha" name="senha" minlength="6" required>
                </div>
                <div class="col-md-6">
                  <label for="confirmar_senha" class="form-label">Confirmar</label>
                  <input type="password" class="form-control" id="confirmar_senha" name="confirmar_senha" required>
                </div>
              </div>

              <!-- Seleção de perfil -->
              <div class="mb-3">
                <label class="form-label fw-bold">Eu sou:</label>
                <div class="row g-2">
                  <div class="col-md-6">
                    <label class="perfil-card selected d-block" data-tipo="aluno">
                      <input type="radio" name="tipo" value="aluno" checked hidden>
                      <i class="bi bi-mortarboard text-primary"></i>
                      <strong>Aluno</strong>
                      <small class="d-block text-muted">Quero avaliar lugares</small>
                    </label>
                  </div>
                  <div class="col-md-6">
                    <label class="perfil-card d-block" data-tipo="proprietario">
                      <input type="radio" name="tipo" value="proprietario" hidden>
                      <i class="bi bi-shop text-success"></i>
                      <strong>Proprietário</strong>
                      <small class="d-block text-muted">Tenho um estabelecimento</small>
                    </label>
                  </div>
                </div>
              </div>

              <button type="submit" class="btn btn-success w-100 mb-3">
                <i class="bi bi-person-plus"></i> Cadastrar
              </button>
            </form>

            <p class="text-center text-muted mb-0">
              Já tem conta? <a href="/login">Faça login</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Seleção visual dos cards de perfil
    document.querySelectorAll('.perfil-card').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll('.perfil-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        card.querySelector('input[type="radio"]').checked = true;
      });
    });
  </script>
</body>
</html>